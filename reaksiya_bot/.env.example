# ============================================================
# Telegram Reaction Master - Environment Variables
# ============================================================

# Master Bot token (from @BotFather)
MASTER_TOKEN=your_master_bot_token_here

# Neon DB PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Owner Telegram User ID (only this user can control master bot)
OWNER_ID=123456789

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# FastAPI server port (Render uses PORT env var automatically)
PORT=8000

# Telegram API ID and Hash (for worker bots script, get from my.telegram.org)
API_ID=1234567
API_HASH=your_api_hash_here
